# Database Connection (Neon PostgreSQL — for Prisma only)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Supabase Credentials
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# ⚠ Service-role key — SERVER ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Stripe Credentials
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Brevo SMTP Configuration
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="your-brevo-smtp-username"
SMTP_PASSWORD="your-brevo-smtp-password"
SMTP_FROM="your-verified-sender@email.com"

# Site Configuration
JWT_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_SITE_URL="https://your-vercel-project.vercel.app"
